{
  "name": "domflax-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "gen": "node packages/patterns/scripts/gen-registry.mjs",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "verify": "npm run typecheck && npm run build && vitest run && node scripts/smoke.mjs",
    "verify:visual": "npx playwright install chromium && vitest run",
    "pretypecheck": "npm run gen",
    "prebuild": "npm run gen",
    "pretest": "npm run gen"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "latest",
    "tsup": "latest",
    "vitest": "latest",
    "@types/node": "latest"
  }
}
