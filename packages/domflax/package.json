{
  "name": "domflax",
  "version": "0.1.2",
  "description": "Compile-time DOM flattener and semantic CSS compressor — fewer DOM nodes, smaller class sets, identical rendered UI.",
  "keywords": [
    "dom",
    "css",
    "tailwind",
    "optimizer",
    "jsx",
    "html",
    "vite-plugin",
    "webpack-plugin",
    "unplugin"
  ],
  "homepage": "https://github.com/Krishnesh-Mishra/domflax#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krishnesh-Mishra/domflax.git"
  },
  "bugs": {
    "url": "https://github.com/Krishnesh-Mishra/domflax/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Krishnesh Mishra",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./pattern-kit": {
      "types": "./dist/pattern-kit.d.ts",
      "import": "./dist/pattern-kit.js",
      "require": "./dist/pattern-kit.cjs"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js",
      "require": "./dist/verify.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "domflax": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node ../../scripts/sync-package-docs.mjs && npm run build"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "postcss-selector-parser": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "postcss-selector-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "magic-string": "^0.30.21",
    "parse5": "^7.3.0"
  },
  "devDependencies": {
    "@domflax/core": "*",
    "@domflax/patterns": "*",
    "@domflax/pattern-kit": "*",
    "@domflax/frontend-jsx": "*",
    "@domflax/frontend-html": "*",
    "@domflax/resolver-tailwind": "*",
    "@domflax/resolver-css": "*",
    "@domflax/verify": "*",
    "@domflax/cli": "*",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.16",
    "postcss-selector-parser": "^7.1.0"
  }
}
